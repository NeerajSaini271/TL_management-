# Application
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/tl_attendance?schema=public"

# Redis
REDIS_URL="redis://localhost:6379/0"

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-chars
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Security
CSRF_SECRET=change-me-csrf-secret-at-least-32-chars
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
